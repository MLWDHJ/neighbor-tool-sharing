.tool-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tool-image {
  width: 100%;
  height: 400rpx;
}

.tool-image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
}

.placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999999;
}

.tool-info {
  padding: 24rpx;
}

.tool-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tool-category,
.tool-condition {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  background-color: #F0F0F0;
  color: #666666;
}

.tool-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.price-free {
  font-size: 32rpx;
  font-weight: bold;
  color: #52C41A;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #F5222D;
}

.deposit {
  font-size: 24rpx;
  color: #999999;
}

.tool-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tool-distance {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.icon-location {
  width: 24rpx;
  height: 24rpx;
}

.tool-status-text {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
}

.status-available {
  background-color: #E8F8F0;
  color: #52C41A;
}

.status-borrowed {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.status-offline {
  background-color: #F0F0F0;
  color: #999999;
}
