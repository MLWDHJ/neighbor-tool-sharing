.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
  filter: grayscale(100%);
  opacity: 0.6;
}

.tab-bar-item.active .tab-icon {
  filter: grayscale(0%);
  opacity: 1;
}

.tab-text {
  font-size: 22rpx;
  color: #999999;
}

.tab-bar-item.active .tab-text {
  color: #4A90E2;
}
