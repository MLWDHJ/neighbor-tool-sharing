.skeleton {
  padding: 20rpx;
}

/* 动画效果 */
.skeleton-animate {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 列表骨架屏 */
.skeleton-item {
  display: flex;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-title {
  width: 70%;
  height: 32rpx;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.skeleton-text {
  width: 100%;
  height: 24rpx;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.skeleton-text.short {
  width: 50%;
}

/* 详情骨架屏 */
.skeleton-detail-image {
  width: 100%;
  height: 500rpx;
  margin-bottom: 30rpx;
}

.skeleton-detail-content {
  padding: 0 20rpx;
}

.skeleton-detail-title {
  width: 80%;
  height: 40rpx;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
}

.skeleton-detail-price {
  width: 30%;
  height: 48rpx;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
}

.skeleton-detail-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.skeleton-name {
  width: 150rpx;
  height: 28rpx;
  border-radius: 4rpx;
}

.skeleton-detail-desc {
  width: 100%;
  height: 28rpx;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.skeleton-detail-desc.short {
  width: 60%;
}

/* 卡片骨架屏 */
.skeleton-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.skeleton-card-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.skeleton-card-title {
  width: 80%;
  height: 28rpx;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.skeleton-card-text {
  width: 50%;
  height: 24rpx;
  border-radius: 4rpx;
}
