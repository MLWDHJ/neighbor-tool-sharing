/**app.wxss**/
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局容器 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #4A90E2;
  color: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-disabled {
  background-color: #CCCCCC;
  color: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 文本样式 */
.text-primary {
  color: #333333;
  font-size: 32rpx;
}

.text-secondary {
  color: #666666;
  font-size: 28rpx;
}

.text-hint {
  color: #999999;
  font-size: 24rpx;
}

.text-link {
  color: #4A90E2;
  font-size: 28rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 24rpx 0;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: #E8F4FF;
  color: #4A90E2;
}

.tag-success {
  background-color: #E8F8F0;
  color: #52C41A;
}

.tag-warning {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.tag-danger {
  background-color: #FFF1F0;
  color: #F5222D;
}

/* 图标样式 */
.icon {
  width: 40rpx;
  height: 40rpx;
}

.icon-large {
  width: 60rpx;
  height: 60rpx;
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.list-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 24rpx;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

.p-10 { padding: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }
