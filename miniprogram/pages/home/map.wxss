.container {
  width: 100%;
  height: 100vh;
  position: relative;
}

/* 地图 */
.map {
  width: 100%;
  height: 100%;
}

/* 顶部操作栏 */
.top-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}

.search-box {
  background-color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-text {
  font-size: 28rpx;
  color: #999;
}

/* 切换按钮 */
.switch-btn {
  position: absolute;
  right: 20rpx;
  top: 140rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.switch-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.switch-text {
  font-size: 20rpx;
  color: #666;
}

/* 定位按钮 */
.location-btn {
  position: absolute;
  right: 20rpx;
  bottom: 260rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.location-icon {
  font-size: 40rpx;
}

/* 工具卡片遮罩 */
.tool-card-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 200;
}

/* 工具卡片 */
.tool-card {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  z-index: 300;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.tool-card.show {
  transform: translateY(0);
}

.card-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.card-content {
  display: flex;
  align-items: center;
}

.tool-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
}

.tool-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-owner {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.owner-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.owner-name {
  font-size: 24rpx;
  color: #666;
}

.tool-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tool-price {
  flex: 1;
}

.free-tag {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
}

.price-text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}

.tool-distance {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 20rpx;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 100;
}

.loading-content {
  background-color: rgba(0, 0, 0, 0.7);
  padding: 30rpx 50rpx;
  border-radius: 12rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}

/* 空状态提示 */
.empty-tip {
  position: absolute;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.7);
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  z-index: 100;
}

.empty-tip text {
  font-size: 26rpx;
  color: #fff;
}
