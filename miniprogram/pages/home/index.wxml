<view class="home-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="goToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索工具名称或描述</text>
    </view>
    <view class="map-btn" bindtap="goToMap">
      <text class="map-icon">🗺️</text>
    </view>
    <view class="filter-btn" bindtap="goToFilter">
      <text class="filter-icon">⚙️</text>
    </view>
  </view>

  <!-- 工具列表 -->
  <view class="tool-list">
    <tool-card 
      wx:for="{{tools}}" 
      wx:key="id" 
      tool="{{item}}"
      userLocation="{{userLocation}}"
    />

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && tools.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && tools.length === 0}}" class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无工具</text>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-btn" bindtap="goToPublish">
    <text class="publish-icon">+</text>
  </view>
</view>
