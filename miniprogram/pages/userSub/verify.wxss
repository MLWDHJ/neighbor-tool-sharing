.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 已认证状态 */
.verified-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.verified-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  font-size: 60rpx;
  color: #fff;
}

.verified-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.verified-desc {
  font-size: 28rpx;
  color: #999;
}

/* 提示信息 */
.tips-section {
  background-color: #fff7e6;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 12rpx;
}

.tips-title {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 上传区域 */
.upload-section {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
}

.upload-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.upload-item {
  margin-bottom: 30rpx;
}

.upload-item:last-of-type {
  margin-bottom: 0;
}

.upload-box {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.upload-preview {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

.upload-label {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 12rpx;
}

/* 隐私声明 */
.privacy-section {
  padding: 30rpx;
  text-align: center;
}

.privacy-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}

/* 提交按钮 */
.submit-section {
  padding: 30rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn.disabled {
  background-color: #ccc;
}

.submit-btn::after {
  border: none;
}
