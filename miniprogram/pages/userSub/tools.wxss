.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 工具列表 */
.tools-list {
  padding: 20rpx;
}

.tool-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tool-main {
  display: flex;
  padding: 24rpx;
}

.tool-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tool-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-category {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.tool-price {
  margin-bottom: 10rpx;
}

.free-tag {
  font-size: 26rpx;
  color: #07c160;
  font-weight: bold;
}

.price-text {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: bold;
}

.tool-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  align-self: flex-start;
}

.tool-status.available {
  background-color: #e8f5e9;
  color: #07c160;
}

.tool-status.borrowed {
  background-color: #fff3e0;
  color: #FF6B35;
}

.tool-status.offline {
  background-color: #f5f5f5;
  color: #999;
}

/* 操作按钮 */
.tool-actions {
  display: flex;
  border-top: 1px solid #f5f5f5;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-right: 1px solid #f5f5f5;
}

.action-btn:last-child {
  border-right: none;
}

.action-btn.edit {
  color: #FF6B35;
}

.action-btn.offline {
  color: #999;
}

.action-btn.online {
  color: #07c160;
}

.action-btn.delete {
  color: #ff4444;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #FF6B35;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.4);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}
