<view class="container">
  <!-- 头像区域 -->
  <view class="avatar-section" bindtap="chooseAvatar">
    <image class="avatar" src="{{avatar || 'https://api.dicebear.com/7.x/avataaars/png?seed=default'}}" mode="aspectFill" />
    <view class="avatar-edit">
      <text class="edit-icon">📷</text>
      <text class="edit-text">更换头像</text>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input 
        class="form-input" 
        placeholder="请输入昵称" 
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <!-- 手机号（只读） -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <text class="form-value readonly">{{userInfo.phone || '未绑定'}}</text>
    </view>

    <!-- 位置 -->
    <view class="form-item" bindtap="chooseLocation">
      <text class="form-label">位置</text>
      <view class="form-value-wrapper">
        <text class="form-value {{location ? '' : 'placeholder'}}">
          {{location || '选择您的位置'}}
        </text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <text class="tips-text">位置信息用于展示附近的工具，方便邻里借用</text>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button 
      class="save-btn {{isSubmitting ? 'disabled' : ''}}" 
      bindtap="saveProfile"
      disabled="{{isSubmitting}}"
    >
      {{isSubmitting ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
