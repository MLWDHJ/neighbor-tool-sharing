<view class="container">
  <!-- 工具列表 -->
  <view class="tools-list" wx:if="{{tools.length > 0}}">
    <view class="tool-card" wx:for="{{tools}}" wx:key="id">
      <view class="tool-main" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="tool-image" src="{{item.images[0]}}" mode="aspectFill" />
        <view class="tool-info">
          <view class="tool-name">{{item.name}}</view>
          <view class="tool-category">{{item.category}}</view>
          <view class="tool-price">
            <text wx:if="{{item.isFree}}" class="free-tag">免费</text>
            <text wx:else class="price-text">¥{{item.rentFee}}/天</text>
          </view>
          <view class="tool-status {{item.status}}">
            <text wx:if="{{item.status === 'available'}}">可借用</text>
            <text wx:elif="{{item.status === 'borrowed'}}">已借出</text>
            <text wx:else>已下架</text>
          </view>
        </view>
      </view>
      
      <view class="tool-actions">
        <view class="action-btn edit" bindtap="goToEdit" data-id="{{item.id}}">
          <text>编辑</text>
        </view>
        <view 
          class="action-btn {{item.status === 'available' ? 'offline' : 'online'}}" 
          bindtap="toggleStatus" 
          data-id="{{item.id}}" 
          data-status="{{item.status}}"
        >
          <text>{{item.status === 'available' ? '下架' : '上架'}}</text>
        </view>
        <view class="action-btn delete" bindtap="deleteTool" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && tools.length === 0}}">
    <text class="empty-icon">🔧</text>
    <text class="empty-text">还没有发布工具</text>
    <view class="empty-btn" bindtap="goToPublish">去发布</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 发布按钮 -->
  <view class="fab-btn" bindtap="goToPublish" wx:if="{{tools.length > 0}}">
    <text class="fab-icon">+</text>
  </view>
</view>
