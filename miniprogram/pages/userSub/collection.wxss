.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 工具列表 */
.tools-list {
  padding: 20rpx;
}

.tool-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tool-main {
  display: flex;
  padding: 24rpx;
}

.tool-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tool-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-owner {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.owner-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.owner-name {
  font-size: 24rpx;
  color: #666;
}

.tool-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.tool-price {
  flex: 1;
}

.free-tag {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
}

.price-text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}

.tool-distance {
  font-size: 24rpx;
  color: #999;
}

.tool-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  align-self: flex-start;
}

.tool-status.available {
  background-color: #e8f5e9;
  color: #07c160;
}

.tool-status.unavailable {
  background-color: #f5f5f5;
  color: #999;
}

/* 操作按钮 */
.tool-actions {
  display: flex;
  border-top: 1px solid #f5f5f5;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-right: 1px solid #f5f5f5;
}

.action-btn:last-child {
  border-right: none;
}

.action-icon {
  margin-right: 8rpx;
}

.action-btn.cancel {
  color: #999;
}

.action-btn.apply {
  color: #FF6B35;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
