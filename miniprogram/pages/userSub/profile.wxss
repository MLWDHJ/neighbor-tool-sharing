.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 头像区域 */
.avatar-section {
  background-color: #fff;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.avatar-edit {
  display: flex;
  align-items: center;
}

.edit-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.edit-text {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  margin-top: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1px solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.form-value {
  font-size: 28rpx;
  color: #333;
}

.form-value.readonly {
  color: #999;
}

.form-value.placeholder {
  color: #ccc;
}

.form-value-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 提示信息 */
.tips-section {
  padding: 30rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
}

/* 保存按钮 */
.save-section {
  padding: 60rpx 30rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn.disabled {
  background-color: #ccc;
}

.save-btn::after {
  border: none;
}
