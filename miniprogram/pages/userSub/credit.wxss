.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 信用分卡片 */
.credit-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.credit-score-wrapper {
  margin-bottom: 30rpx;
}

.credit-score {
  font-size: 120rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.credit-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

.credit-level {
  margin-bottom: 20rpx;
}

.level-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.level-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.credit-tips {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 信用说明 */
.info-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info-icon.add {
  background-color: #e8f5e9;
  color: #07c160;
}

.info-icon.minus {
  background-color: #ffebee;
  color: #ff4444;
}

.info-content {
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.info-desc {
  font-size: 24rpx;
  color: #999;
}

/* 信用历史 */
.history-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
}

.history-reason {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-right {
  font-size: 32rpx;
  font-weight: bold;
}

.history-right.positive {
  color: #07c160;
}

.history-right.negative {
  color: #ff4444;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
