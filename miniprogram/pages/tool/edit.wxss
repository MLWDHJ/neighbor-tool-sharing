.edit-tool-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 80px;
}

.content {
  height: calc(100vh - 80px);
}

/* 区块 */
.section {
  background-color: #fff;
  margin-bottom: 12px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 16px;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.image-item {
  position: relative;
  width: 100px;
  height: 100px;
}

.image {
  width: 100%;
  height: 100%;
  border-radius: 8px;
}

.delete-btn {
  position: absolute;
  top: -8px;
  right: -8px;
  width: 24px;
  height: 24px;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 12px;
  height: 12px;
}

.upload-btn {
  width: 100px;
  height: 100px;
  border: 1px dashed #DDD;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 32px;
  height: 32px;
  margin-bottom: 8px;
}

.upload-text {
  font-size: 12px;
  color: #999;
}

/* 表单项 */
.form-item {
  margin-bottom: 16px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}

.required {
  color: #FF6B35;
}

.input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
}

.picker {
  width: 100%;
  height: 44px;
  line-height: 44px;
  padding: 0 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
  color: #333;
}

.textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #999;
  margin-top: 8px;
}

/* 复选框组 */
.checkbox-group {
  display: flex;
  gap: 24px;
}

.checkbox-item {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #333;
}

.checkbox-item checkbox {
  margin-right: 8px;
}

/* 状态操作 */
.status-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.status-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: #F5F5F5;
  color: #666;
  border-radius: 4px;
  font-size: 14px;
}

.status-btn.primary {
  background-color: #FF6B35;
  color: #fff;
}

.status-hint {
  font-size: 12px;
  color: #999;
  text-align: center;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background-color: #fff;
  border-top: 1px solid #E5E5E5;
}

.submit-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: #FF6B35;
  color: #fff;
  border-radius: 22px;
  font-size: 16px;
  font-weight: bold;
}
