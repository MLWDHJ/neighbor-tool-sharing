.detail-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #F5F5F5;
}

.card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #F0F0F0;
  color: #666666;
  font-size: 24rpx;
  border-radius: 4rpx;
}

.tool-images {
  width: 100%;
  height: 600rpx;
}

.tool-image {
  width: 100%;
  height: 100%;
}

.tool-info {
  margin-bottom: 20rpx;
}

.tool-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tool-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.tool-status text {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
}

.status-available {
  background-color: #E8F8F0;
  color: #52C41A;
}

.status-borrowed {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.status-offline {
  background-color: #F0F0F0;
  color: #999999;
}

.expected-return {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #FFF7E6;
  border-radius: 4rpx;
}

.expected-return-text {
  font-size: 24rpx;
  color: #FA8C16;
}

.tool-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tool-price {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #E5E5E5;
  border-bottom: 1rpx solid #E5E5E5;
  margin-bottom: 24rpx;
}

.price-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.price-item .label {
  font-size: 24rpx;
  color: #999999;
}

.price-item .value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.price-item .value.free {
  color: #52C41A;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.tool-description {
  margin-top: 24rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.lender-info {
  margin-bottom: 20rpx;
}

.lender-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.lender-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.lender-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lender-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.lender-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.credit-score {
  color: #4A90E2;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

.borrow-history {
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.user-name {
  font-size: 28rpx;
  color: #333333;
}

.history-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.history-rating {
  font-size: 24rpx;
}

.rating-stars {
  color: #FFA940;
}

.history-date {
  font-size: 24rpx;
  color: #999999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
}

.borrow-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
}

.borrow-btn.disabled {
  background: #CCCCCC;
}
