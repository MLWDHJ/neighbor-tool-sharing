<view class="container">
  <!-- 顶部操作栏 -->
  <view class="header">
    <view class="unread-count">
      未读消息：<text>{{unreadCount}}</text>
    </view>
    <view class="mark-all-read" wx:if="{{unreadCount > 0}}" bindtap="markAllAsRead">
      全部已读
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y bindscrolltolower="loadMore">
    <view wx:if="{{messages.length > 0}}">
      <view wx:for="{{messages}}" wx:key="id" class="message-wrapper">
        <view class="message-item {{item.isRead ? '' : 'unread'}}" bindtap="handleMessageTap" data-item="{{item}}">
          <view class="message-content">
            <!-- 消息图标 -->
            <view class="message-icon icon-{{item.iconType}}">
              <text class="icon-text">{{item.iconText}}</text>
            </view>

            <!-- 消息详情 -->
            <view class="message-detail">
              <view class="message-header">
                <text class="message-title">{{item.title}}</text>
                <text class="message-time">{{item.timeText}}</text>
              </view>
              <text class="message-text">{{item.content}}</text>
            </view>
          </view>
        </view>

        <!-- 删除按钮 -->
        <view class="delete-action">
          <view class="delete-btn" catchtap="deleteMessage" data-id="{{item.id}}" data-index="{{index}}">
            删除
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{messages.length === 0 && !loading}}" class="empty-state">
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无消息</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && messages.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
