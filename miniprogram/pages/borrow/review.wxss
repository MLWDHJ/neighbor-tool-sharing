.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 工具信息卡片 */
.tool-card {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.tool-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
}

.tool-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.borrow-time {
  font-size: 24rpx;
  color: #999;
}

/* 评分区域 */
.rating-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
  text-align: center;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: left;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.star {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-icon {
  font-size: 60rpx;
  color: #ddd;
  transition: all 0.2s;
}

.star.active .star-icon {
  color: #FF6B35;
}

.rating-text {
  font-size: 28rpx;
  color: #FF6B35;
}

/* 标签区域 */
.tags-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-item.active {
  background-color: #fff5f0;
  color: #FF6B35;
  border-color: #FF6B35;
}

/* 评价内容区域 */
.content-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.optional-tag {
  font-size: 22rpx;
  color: #999;
}

.content-input-wrapper {
  position: relative;
}

.content-input {
  width: 100%;
  height: 240rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.content-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 22rpx;
  color: #999;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn.disabled {
  background-color: #ccc;
}

.submit-btn::after {
  border: none;
}
