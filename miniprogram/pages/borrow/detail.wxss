.borrow-detail-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 80px;
}

.content {
  height: calc(100vh - 80px);
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24px 16px;
  text-align: center;
  color: #fff;
}

.status-badge {
  display: inline-block;
  padding: 6px 16px;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 16px;
  font-size: 14px;
  margin-bottom: 8px;
}

.status-badge.pending {
  background-color: rgba(255, 193, 7, 0.3);
}

.status-badge.approved {
  background-color: rgba(76, 175, 80, 0.3);
}

.status-badge.rejected {
  background-color: rgba(244, 67, 54, 0.3);
}

.status-badge.returned {
  background-color: rgba(33, 150, 243, 0.3);
}

.status-badge.completed {
  background-color: rgba(156, 39, 176, 0.3);
}

.status-time {
  font-size: 12px;
  opacity: 0.8;
}

/* 区块 */
.section {
  background-color: #fff;
  margin-bottom: 12px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 16px;
}

/* 工具信息 */
.tool-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.tool-image {
  width: 60px;
  height: 60px;
  border-radius: 4px;
}

.tool-content {
  flex: 1;
}

.tool-name {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.tool-category {
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.tool-price .free {
  color: #4CAF50;
  font-size: 14px;
  font-weight: bold;
}

.tool-price .price {
  color: #FF6B35;
  font-size: 14px;
  font-weight: bold;
}

.arrow-icon {
  width: 16px;
  height: 16px;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 24px;
}

.user-content {
  flex: 1;
}

.user-name {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.user-credit {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #FF6B35;
}

.star-icon {
  width: 14px;
  height: 14px;
  margin-right: 4px;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row.total {
  padding-top: 12px;
  border-top: 1px solid #E5E5E5;
  font-weight: bold;
}

.info-row .label {
  font-size: 14px;
  color: #666;
}

.info-row .value {
  font-size: 14px;
  color: #333;
  text-align: right;
  max-width: 60%;
}

.info-row .value.price {
  color: #FF6B35;
  font-weight: bold;
}

.info-row .value.damaged {
  color: #F44336;
}

/* 拒绝原因 */
.reject-reason {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

/* 底部操作 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background-color: #fff;
  border-top: 1px solid #E5E5E5;
}

.actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  font-size: 16px;
  font-weight: bold;
}

.action-btn.reject {
  background-color: #F5F5F5;
  color: #666;
}

.action-btn.approve {
  background-color: #4CAF50;
  color: #fff;
}

.action-btn.primary {
  background-color: #FF6B35;
  color: #fff;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 400px;
  background-color: #fff;
  border-radius: 12px;
  padding: 20px;
}

.modal-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 16px;
  text-align: center;
}

.modal-textarea {
  width: 100%;
  min-height: 80px;
  padding: 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
  margin-bottom: 16px;
}

.modal-form {
  margin-bottom: 16px;
}

.form-item {
  margin-bottom: 12px;
}

.form-item .label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}

.form-item .textarea {
  width: 100%;
  min-height: 60px;
  padding: 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
}

.form-item .input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  background-color: #F5F5F5;
  border-radius: 4px;
  font-size: 14px;
}

.modal-actions {
  display: flex;
  gap: 12px;
}

.modal-btn {
  flex: 1;
  height: 40px;
  line-height: 40px;
  border-radius: 20px;
  font-size: 14px;
}

.modal-btn.cancel {
  background-color: #F5F5F5;
  color: #666;
}

.modal-btn.confirm {
  background-color: #FF6B35;
  color: #fff;
}
