<view class="login-container">
  <view class="logo-section">
    <text class="logo">🔧</text>
    <text class="app-name">邻里工具共享</text>
    <text class="app-slogan">让闲置工具流动起来</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <text class="label">手机号</text>
      <input 
        class="input" 
        type="number" 
        maxlength="11" 
        placeholder="请输入手机号" 
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="input-group">
      <text class="label">验证码</text>
      <view class="code-input-wrapper">
        <input 
          class="input code-input" 
          type="number" 
          maxlength="6" 
          placeholder="请输入验证码" 
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button 
          class="send-code-btn {{canSendCode ? '' : 'disabled'}}" 
          bindtap="sendCode"
          disabled="{{!canSendCode}}"
        >
          {{codeButtonText}}
        </button>
      </view>
    </view>

    <button class="login-btn {{canLogin ? '' : 'disabled'}}" bindtap="login" disabled="{{!canLogin}}">
      登录
    </button>

    <view class="tips">
      <text>登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
