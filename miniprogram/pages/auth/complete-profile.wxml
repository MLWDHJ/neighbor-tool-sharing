<view class="container">
  <view class="header">
    <text class="title">完善个人信息</text>
    <text class="subtitle">让邻居更好地认识你</text>
  </view>

  <view class="form">
    <!-- 头像上传 -->
    <view class="form-item">
      <text class="label">头像 <text class="required">*</text></text>
      <view class="avatar-upload" bindtap="chooseAvatar">
        <image wx:if="{{avatar}}" src="{{avatar}}" class="avatar" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="iconfont icon-camera"></text>
          <text class="hint">点击上传</text>
        </view>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-item">
      <text class="label">昵称 <text class="required">*</text></text>
      <input 
        class="input" 
        placeholder="请输入昵称" 
        value="{{nickname}}"
        maxlength="20"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 位置信息 -->
    <view class="form-item">
      <text class="label">所在位置 <text class="required">*</text></text>
      <view class="location-picker" bindtap="chooseLocation">
        <text class="{{location ? 'location-text' : 'placeholder'}}">
          {{location || '点击选择位置'}}
        </text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">真实的信息有助于建立邻里信任</text>
  </view>

  <button class="submit-btn" bindtap="submit">完成</button>
</view>
